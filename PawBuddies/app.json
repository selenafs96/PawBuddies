{
  "expo": {
    "name": "PawBuddies",
    "slug": "PawBuddies",
    "version": "1.0.0",
    "scheme": "pawbuddies",
    "extra": {
      "router": {
        "origin": false
      }
    },
    "orientation": "portrait",
    "icon": "./assets/icons/Logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icons/Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/logo_principal.png"
      },
      "package": "com.anonymous.PawBuddies"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router"
    ]
  }
}
